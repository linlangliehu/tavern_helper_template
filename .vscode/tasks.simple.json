{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "简化版：启动开发环境",
      "dependsOn": [
        "简化版：pnpm watch",
        "简化版：静态服务器 (端口 5510)",
        "简化版：启动 Chrome 调试"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "简化版：pnpm watch",
      "type": "shell",
      "command": "pnpm",
      "args": ["watch"],
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".*",
              "file": 1,
              "location": 2,
              "message": 3
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": "webpack (?:\\d+\\.){2}\\d+ compiled"
          }
        }
      ],
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
      }
    },
    {
      "label": "简化版：静态服务器 (端口 5510)",
      "type": "shell",
      "command": "node",
      "args": ["scripts/mfrs-dev-server-simple.mjs"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "static-server",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting static server",
          "endsPattern": "Static server running"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false
      }
    },
    {
      "label": "简化版：启动 Chrome 调试",
      "type": "shell",
      "command": ".vscode\\start-chrome-debug.cmd",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "echo": false,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false
      }
    },
    {
      "label": "简化版：切换到开发模式",
      "type": "shell",
      "command": "node",
      "args": ["scripts/toggle-dev-mode.mjs", "--enable"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "简化版：切换回生产模式",
      "type": "shell",
      "command": "node",
      "args": ["scripts/toggle-dev-mode.mjs", "--disable"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      }
    }
  ]
}
