{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MFRS: 实时开发当前工作树",
      "type": "chrome",
      "request": "attach",
      "preLaunchTask": "MFRS: 开始实时开发",
      "port": 9222,
      "timeout": 30000,
      "sourceMapPathOverrides": {
        "src://tavern_helper_template/*": "${workspaceFolder}/*",
        "webpack://tavern_helper_template/*": "${workspaceFolder}/*"
      },
      "skipFiles": ["**/jquery*.min.js", "**/node_modules/**"]
    },
    {
      "name": "编译代码并调试酒馆网页 (Chrome)",
      "type": "chrome",
      "request": "attach",
      "preLaunchTask": "开始任务",
      "port": 9222,
      "timeout": 30000,
      "sourceMapPathOverrides": {
        "src://tavern_helper_template/*": "${workspaceFolder}/*",
        "webpack://tavern_helper_template/*": "${workspaceFolder}/*"
      },
      "skipFiles": ["**/jquery*.min.js", "**/node_modules/**"]
    },
    {
      "name": "仅附加到 Chrome",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "timeout": 30000,
      "sourceMapPathOverrides": {
        "src://tavern_helper_template/*": "${workspaceFolder}/*",
        "webpack://tavern_helper_template/*": "${workspaceFolder}/*"
      },
      "skipFiles": ["**/jquery*.min.js", "**/node_modules/**"]
    }
  ]
}