// 键盘 F5（笔记本常为 Fn+F5）= 启动开发环境。
// preLaunchTask 触发任务链：切换到开发模式 → pnpm watch → 静态服务器（端口 5510）。
// 不再启动/附加任何 Chrome —— 用内置浏览器或你自己的浏览器打开 http://127.0.0.1:8000/ 查看效果。
// 开发完成后运行任务「切换回生产模式」还原 YAML 再发布。
{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "启动开发环境",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "启动开发环境",
      "command": "echo 开发环境已启动（开发模式 + watch + 静态服务 5510）。浏览器打开 http://127.0.0.1:8000/ 查看效果"
    }
  ]
}
